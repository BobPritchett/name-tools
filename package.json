{
  "name": "name-tools",
  "version": "0.1.0",
  "description": "A utility library for parsing, formatting, and manipulating person names",
  "packageManager": "pnpm@11.0.0+sha512.5bd187500e49cc6c3d891d973b432c02b844a5eb7209172c90a517a3ef4f579ed5c23d409b699e6a9dc418ff7b2b1890e63f6d74f1d3fc49848f37779c89c84c",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./gender/all": {
      "types": "./dist/gender/all.d.ts",
      "import": "./dist/gender/all.mjs",
      "require": "./dist/gender/all.js"
    },
    "./gender/coverage99": {
      "types": "./dist/gender/coverage99.d.ts",
      "import": "./dist/gender/coverage99.mjs",
      "require": "./dist/gender/coverage99.js"
    },
    "./gender/coverage95": {
      "types": "./dist/gender/coverage95.d.ts",
      "import": "./dist/gender/coverage95.mjs",
      "require": "./dist/gender/coverage95.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts && tsup src/gender/all.ts src/gender/coverage99.ts src/gender/coverage95.ts --format cjs,esm --dts --outDir dist/gender && tsup src/docs-entry.ts --format esm --outDir docs --no-dts && node scripts/copy-docs.js",
    "build:gender": "node scripts/build-gender-data.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "dev": "tsup src/docs-entry.ts --format esm --outDir docs --watch --onSuccess \"node scripts/copy-docs.js\""
  },
  "keywords": [
    "name",
    "parser",
    "formatter",
    "person",
    "names",
    "utilities"
  ],
  "author": "Bob Pritchett",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BobPritchett/name-tools.git"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
